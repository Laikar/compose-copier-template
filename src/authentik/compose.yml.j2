---
services:
  db:
    image: docker.io/library/postgres:16-alpine
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d ${POSTGRES_DB} -U ${POSTGRES_USER} "]
      start_period: 20s
      interval: 30s
      retries: 5
      timeout: 5s
    volumes:
      - "authentik-postgresql:/var/lib/postgresql/data"
    env_file:
      - .secrets/db.env
    networks:
      atk_network:
  server:
    container_name: authentik_server
    image: ghcr.io/goauthentik/server:2025.12
    restart: unless-stopped
    command: server
    env_file:
      - .secrets/authentik.env
    volumes:
      - "${AUTHENTIK_DATA_DIR}/media:/media:z"
      - "${AUTHENTIK_DATA_DIR}/custom-templates:/templates:z"
    networks:
      atk_network:
      internal_net:

    depends_on:
      - db
    expose:
      - 9000

  worker:
    image: ghcr.io/goauthentik/server:2025.12
    restart: unless-stopped
    command: worker
    depends_on:
      - db
    env_file:
      - .secrets/authentik.env
    user: "root"
    volumes:
      - "${AUTHENTIK_DATA_DIR}/media:/media:z"
      - "${AUTHENTIK_DATA_DIR}/certs:/certs:z"
      - "${AUTHENTIK_DATA_DIR}/custom-templates:/templates:z"
    networks:
      atk_network:
      internal_net:

  ldap_outpost:
    hostname: ldap_outpost
    image: ghcr.io/goauthentik/ldap:2025.12
    restart: unless-stopped
    env_file:
      - .secrets/ldap.env
      - .secrets/ldap_token.env
    networks:
      atk_network:
      internal_net:

networks:
  atk_network:
  internal_net:
    external: true

volumes:
  authentik-redis:
  authentik-postgresql:
